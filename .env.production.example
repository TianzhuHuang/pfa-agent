# PFA 生产环境变量模板
# 复制到 ECS 的 /opt/pfa/.env，填入实际值
# 不要提交包含真实密钥的文件到 Git

# 通义千问 API（AI 对话、OCR、分析）
DASHSCOPE_API_KEY=sk-REPLACE_ME

# Supabase（后端）— 必须配置，否则持仓数据走 SQLite/JSON，Supabase 表始终为空
# Service Role Key 在 Supabase Dashboard → Settings → API → service_role（secret）
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=SUPABASE_SERVICE_ROLE_KEY_REPLACE_ME
# JWT 验证：JWKS 失败时回退 HS256，需填入 Supabase Dashboard → Settings → API → JWT Secret（长字符串，非 Key ID）
SUPABASE_JWT_SECRET=SUPABASE_JWT_SECRET_REPLACE_ME

# 站点 URL（Auth 回调、CORS 等动态适配）
NEXT_PUBLIC_SITE_URL=https://pfa.shareyourhealth.cn
SITE_URL=https://pfa.shareyourhealth.cn

# CORS 允许的前端域名（可省略，默认用 SITE_URL）
CORS_ORIGINS=https://pfa.shareyourhealth.cn

# 前端构建时注入
NEXT_PUBLIC_API_URL=https://pfa.shareyourhealth.cn
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUPABASE_ANON_KEY_REPLACE_ME

# Finnhub（美股/加密补全等）
FINNHUB_API_KEY=FINNHUB_API_KEY_REPLACE_ME