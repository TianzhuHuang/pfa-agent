{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pfa.example.com/user-profile.schema.json",
  "title": "PFA User Profile",
  "description": "用户配置：持仓、关注渠道、投资偏好。用于规范持仓录入方式与后续 Agent 行为。",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema 版本，便于后续兼容"
    },
    "holdings": {
      "type": "array",
      "description": "用户持仓列表。支持多种录入来源：OCR、手动、浏览器、Excel。",
      "items": { "$ref": "#/$defs/Position" }
    },
    "channels": {
      "type": "object",
      "description": "用户关注的信息渠道（RSS、雪球、Twitter 等）",
      "properties": {
        "rss_urls": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "xueqiu_user_ids": { "type": "array", "items": { "type": "string" } },
        "twitter_handles": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "preferences": {
      "type": "object",
      "description": "投资偏好与约束（可由用户或纠偏接口更新）",
      "properties": {
        "style": { "type": "string", "enum": ["value", "growth", "short_term", "long_term"], "description": "投资风格" },
        "frequency": { "type": "string", "enum": ["daily", "weekly", "hold"], "description": "操作频次" },
        "risk_tolerance": { "type": "string", "enum": ["low", "medium", "high"], "description": "风险容忍度" },
        "constraints": { "type": "string", "description": "约束说明，如：不用杠杆、只做 A 股" }
      }
    },
    "accounts": {
      "type": "array",
      "description": "账户元数据：名称、结算币种、类型",
      "items": { "$ref": "#/$defs/Account" }
    }
  },
  "required": ["version"],
  "$defs": {
    "Account": {
      "type": "object",
      "description": "账户定义",
      "properties": {
        "id": { "type": "string", "description": "账户 ID" },
        "name": { "type": "string", "description": "账户名称" },
        "base_currency": { "type": "string", "enum": ["CNY", "USD", "HKD"], "description": "结算币种（推荐）" },
        "currency": { "type": "string", "enum": ["CNY", "USD", "HKD"], "description": "结算币种（兼容旧数据，等同于 base_currency）" },
        "broker": { "type": "string", "description": "券商/托管方" },
        "account_type": { "type": "string", "enum": ["股票", "债券", "数字货币", "其他"], "description": "账户类型" },
        "balance": { "type": "number", "minimum": 0, "description": "可用余额（结算币种）" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["name"],
      "anyOf": [
        { "required": ["base_currency"] },
        { "required": ["currency"] }
      ]
    },
    "Position": {
      "type": "object",
      "description": "单条持仓记录",
      "properties": {
        "symbol": {
          "type": "string",
          "description": "标的代码，如 600519、AAPL、00700.HK"
        },
        "name": {
          "type": "string",
          "description": "标的名称（可选，便于展示）"
        },
        "cost_price": {
          "type": "number",
          "minimum": 0,
          "description": "成本价"
        },
        "quantity": {
          "type": "number",
          "minimum": 0,
          "description": "持仓数量（股/份）"
        },
        "position_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "仓位占比%（可选，与 quantity 二选一或同时存在）"
        },
        "market": {
          "type": "string",
          "enum": ["A", "US", "HK", "OTHER"],
          "description": "所属市场：A=A股, US=美股, HK=港股, OTHER=其他"
        },
        "currency": {
          "type": "string",
          "enum": ["CNY", "USD", "HKD"],
          "description": "标的原始币种（覆盖 market 推断，用于 OCR 纠偏）"
        },
        "exchange": {
          "type": "string",
          "description": "交易所代码，如 NYSE、HKEX、SGX、SSE、SZSE（T14 等多地上市时用于区分）"
        },
        "source": {
          "type": "string",
          "enum": ["ocr", "manual", "browser", "excel", "csv", "search"],
          "description": "录入来源：ocr=截图识别, manual=手动输入, browser=Agent 浏览器读取, excel=Excel 导入, csv=CSV 导入, search=搜索添加"
        },
        "ocr_confirmed": {
          "type": "boolean",
          "description": "OCR 导入后是否已人工确认（source=ocr 时默认 false，编辑保存后置 true）"
        },
        "price_deviation_warn": {
          "type": "boolean",
          "description": "OCR 识别价格与实时价偏差 >5% 时标记，供前端展示黄色提示"
        },
        "account": {
          "type": "string",
          "description": "券商账户名称（如：平安证券、富途、默认）"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "该条记录最后更新时间（ISO 8601）"
        },
        "current_price": {
          "type": "number",
          "description": "现价（运行时计算，可选存储）"
        },
        "memo_history": {
          "type": "array",
          "description": "投资备忘录：记录每次操作的思考逻辑",
          "items": {
            "type": "object",
            "properties": {
              "time": { "type": "string", "format": "date-time" },
              "action": { "type": "string", "enum": ["buy", "sell", "hold", "watch", "note"] },
              "text": { "type": "string", "description": "备忘内容：为什么做这个决策" },
              "quantity_change": { "type": "number", "description": "数量变动（正=买入，负=卖出）" },
              "price": { "type": "number", "description": "操作价格" }
            },
            "required": ["time", "action", "text"]
          }
        }
      },
      "required": ["symbol", "market", "source"],
      "additionalProperties": false
    }
  }
}
